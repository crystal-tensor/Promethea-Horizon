+#[pyfunction]
+#[pyo3(signature = (dag, target, config, *, strict_direction=false, operation_order="native"))]
+pub fn vf2_layout_pass_average_traced(
+    dag: &DAGCircuit,
+    target: &Target,
+    config: &Vf2PassConfiguration,
+    strict_direction: bool,
+    operation_order: &str,
+) -> PyResult<(Vf2PassReturn, Vec<ErrorMapTraceRow>)> {
+    let operation_order = match operation_order {
+        "native" => ErrorMapOperationOrder::Native,
+        "ascending" => ErrorMapOperationOrder::Ascending,
+        "descending" => ErrorMapOperationOrder::Descending,
+        value => {
+            return Err(PyValueError::new_err(format!(
+                "invalid ErrorMap operation order: {value}"
+            )));
+        }
+    };
+    let Some((error_map, trace_rows)) = build_average_error_map_traced(target, operation_order)
+    else {
+        return Ok((Vf2PassReturn::NoSolution, Vec::new()));
+    };
+    let result = vf2_layout_pass_average(dag, target, config, strict_direction, Some(&error_map))?;
+    Ok((result, trace_rows))
+}
